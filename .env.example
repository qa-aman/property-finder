# Copy to .env and fill in. Config is validated at startup (fail-fast).

# LLM: Google Gemini (Google AI Studio key). Required unless USE_STUB_ADAPTERS=true.
GEMINI_API_KEY=

# Google Maps key with Routes API, Places API (New), and Geocoding API enabled on it.
# Required unless USE_STUB_ADAPTERS=true.
GOOGLE_MAPS_API_KEY=

# Sentiment uses Gemini + Google Search grounding (the GEMINI_API_KEY above), so no
# Reddit or other key is needed.

# Set true to run the full flow with in-memory fakes (no external keys needed).
USE_STUB_ADAPTERS=

# Optional. The city is normally provided per search in the request brief, so the
# POC works for any city. Set this only as a demo fallback (e.g. DEFAULT_CITY=Mumbai).
DEFAULT_CITY=
